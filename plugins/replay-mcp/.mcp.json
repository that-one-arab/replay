{
  "mcpServers": {
    "replay": {
      "command": "node",
      "args": [
        "./scripts/replay-bootstrap.mjs",
        "replay-mcp"
      ],
      "cwd": ".",
      "env": {
        "REPLAY_RELEASE_URL": "https://share.replaythis.io/v1/releases",
        "REPLAY_RUNTIME_VERSION": "0.2.2",
        "REPLAY_SHARE_URL": "https://share.replaythis.io"
      }
    }
  }
}
